#!/usr/bin/env bash
#
# guided-dev — Externally orchestrated dev workflow using the claude CLI.
# Chains multiple claude invocations with -c (continue) to preserve context
# across phases: plan → implement → review → respond → apply → validate.

set -o pipefail

# ── Colors ──────────────────────────────────────────────────────────────────

bold='\033[1m'
dim='\033[2m'
blue='\033[1;34m'
green='\033[1;32m'
yellow='\033[1;33m'
cyan='\033[1;36m'
magenta='\033[1;35m'
red='\033[1;31m'
reset='\033[0m'

phase() {
  local num="$1" name="$2" color="$3"
  echo ""
  echo -e "${dim}─────────────────────────────────────────────────────────${reset}"
  echo -e "${color}${bold}  Phase ${num}: ${name}${reset}"
  echo -e "${dim}─────────────────────────────────────────────────────────${reset}"
  echo ""
}

# ── Exit-code helper ────────────────────────────────────────────────────────
# Interactive claude sessions return non-zero on Ctrl+D / /exit.
# Ask the user whether to continue instead of aborting outright.

check_exit() {
  local code=$1 phase_name="$2"
  if [[ $code -ne 0 ]]; then
    echo ""
    echo -e "${yellow}⚠  ${phase_name} exited with code ${code}.${reset}"
    read -r -p "Continue to next phase? [Y/n] " answer
    case "${answer,,}" in
      n|no) echo "Aborting."; exit 1 ;;
    esac
  fi
}

# ── Phase 1: Collect goal ───────────────────────────────────────────────────

phase 1 "Collect Goal" "$blue"
echo -e "${dim}Describe what you want to build or change.${reset}"
echo -e "${dim}(Multi-line: enter an empty line to finish)${reset}"
echo ""

goal_lines=()
while IFS= read -r -p "> " line; do
  [[ -z "$line" ]] && break
  goal_lines+=("$line")
done

if [[ ${#goal_lines[@]} -eq 0 ]]; then
  echo "No goal provided. Aborting."
  exit 1
fi

goal=$(printf '%s\n' "${goal_lines[@]}")

echo ""
echo -e "${green}Goal captured.${reset}"

# ── Phase 2: Plan (read-only) ──────────────────────────────────────────────

phase 2 "Plan" "$cyan"
echo -e "${dim}Claude will explore the codebase and produce a plan.${reset}"
echo -e "${dim}Permission mode: plan (read-only). Ask questions, refine, approve.${reset}"
echo -e "${bold}Type /exit when the plan is approved to continue to implementation.${reset}"
echo ""

claude --permission-mode plan \
  "You are in the planning phase (Phase 2 of 7) of a guided development workflow. The user's goal is:

${goal}

Your task:
- Read the repo to understand the codebase
- Ask guiding questions if the goal is unclear (2-3 per message max)
- Produce a structured implementation plan
- Wait for the user to approve before finishing

IMPORTANT: This is an interactive session within a multi-phase workflow. When the user approves the plan, summarize it one final time and tell the user to type /exit to advance to the implementation phase."
rc=$?
check_exit $rc "Plan"

# ── Phase 3: Implement ─────────────────────────────────────────────────────

phase 3 "Implement" "$green"
echo -e "${dim}Claude will implement the approved plan.${reset}"
echo -e "${bold}Type /exit when implementation is complete to continue to code review.${reset}"
echo ""

claude -c \
  "You are now in the implementation phase (Phase 3 of 7) of a guided development workflow. Implement the plan that was just approved in the planning phase:
- Implement the approved plan
- Commit to the approach agreed upon — do not deviate without informing the user
- Write clean, idiomatic code that follows existing project conventions

Implement the changes now. When you are finished, tell the user to type /exit to advance to the code review phase."
rc=$?
check_exit $rc "Implement"

# ── Phase 4: Code review (automated) ───────────────────────────────────────

phase 4 "Code Review" "$yellow"
echo -e "${dim}Running automated code review on the diff...${reset}"
echo ""

review_output=$(claude -c -p "/code-review")
rc=$?
echo "$review_output"
check_exit $rc "Code Review"

# ── Phase 5: Review response (automated) ───────────────────────────────────

phase 5 "Review Response" "$magenta"
echo -e "${dim}Evaluating review suggestions (ACCEPT/REJECT/DISCUSS)...${reset}"
echo ""

response_output=$(claude -c -p "/code-review-response")
rc=$?
echo "$response_output"
check_exit $rc "Review Response"

# ── Phase 6: Apply suggestions ─────────────────────────────────────────────

phase 6 "Apply Suggestions" "$green"
echo -e "${dim}Claude will implement ACCEPTed suggestions and ask about DISCUSS items.${reset}"
echo -e "${bold}Type /exit when done to continue to validation.${reset}"
echo ""

claude -c \
  "You are now in the suggestion-application phase (Phase 6 of 7) of a guided development workflow. The code review and response evaluation have already run in this conversation.

Apply the results:
- Implement all suggestions that were marked ACCEPT
- For DISCUSS items, present them to the user and ask for a decision
- Skip REJECT items

If there are no ACCEPT or DISCUSS items, say so.

When you are finished, tell the user to type /exit to advance to the validation phase."
rc=$?
check_exit $rc "Apply Suggestions"

# ── Phase 7: Validate ──────────────────────────────────────────────────────

phase 7 "Validate" "$cyan"
echo -e "${dim}Running full validation workflow...${reset}"
echo -e "${bold}Type /exit when validation is complete to finish.${reset}"
echo ""

claude -c "/code-change-validator"
rc=$?
check_exit $rc "Validate"

# ── Done ────────────────────────────────────────────────────────────────────

echo ""
echo -e "${dim}─────────────────────────────────────────────────────────${reset}"
echo -e "${green}${bold}  Dev workflow complete.${reset}"
echo -e "${dim}─────────────────────────────────────────────────────────${reset}"
echo ""
