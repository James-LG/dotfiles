#!/usr/bin/env bash
# git wta <branch> [<commit-ish>]
# Add a worktree at ../<repo>-<branch> and sync tms bookmarks.
set -euo pipefail

branch="${1:-}"
if [[ -z "$branch" ]]; then
  echo "usage: git wta <branch> [<commit-ish>]" >&2
  exit 1
fi

repo_name="$(basename "$(git rev-parse --show-toplevel)")"
worktree_path="$HOME/.worktrees/${repo_name}-${branch}"
mkdir -p "$HOME/.worktrees"

git worktree add "$worktree_path" "${2:-$branch}"
tms-sync-worktrees
